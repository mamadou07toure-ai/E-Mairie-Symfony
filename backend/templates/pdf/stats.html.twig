<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Rapport Statistique</title>
    <style>
        body { font-family: 'Helvetica', 'Arial', sans-serif; font-size: 12px; color: #333; }
        .header { text-align: center; margin-bottom: 30px; border-bottom: 2px solid #0F2D6B; padding-bottom: 10px; }
        h1 { color: #0F2D6B; font-size: 20px; margin: 5px 0; }
        .date { text-align: right; font-size: 10px; color: #666; margin-bottom: 20px; }
        .kpi-container { width: 100%; margin-bottom: 30px; border-collapse: collapse; }
        .kpi-container td { width: 33%; padding: 15px; border: 1px solid #ddd; text-align: center; background-color: #f8fafc; }
        .kpi-value { font-size: 24px; font-weight: bold; color: #0F2D6B; display: block; margin-bottom: 5px; }
        .kpi-label { font-size: 11px; text-transform: uppercase; color: #64748b; font-weight: bold; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        th { background-color: #f8fafc; color: #0F2D6B; font-weight: bold; }
        .chart-placeholder { width: 100%; height: 200px; background-color: #f1f5f9; border: 1px dashed #ccc; text-align: center; line-height: 200px; color: #94a3b8; margin-bottom: 20px; }
        .footer { position: fixed; bottom: -20px; left: 0; right: 0; height: 30px; text-align: center; font-size: 10px; border-top: 1px solid #ddd; padding-top: 10px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>SMART E-MAIRIE - RAPPORTS</h1>
        <p>Statistiques et Performances du Système</p>
    </div>
    
    <div class="date">Période du : {{ periode_debut }} au {{ periode_fin }} | Généré le {{ "now"|date("d/m/Y H:i") }}</div>

    <table class="kpi-container">
        <tr>
            <td>
                <span class="kpi-value">{{ kpis.total_demandes|default(0) }}</span>
                <span class="kpi-label">Dossiers Créés</span>
            </td>
            <td>
                <span class="kpi-value" style="color: #059669;">{{ kpis.validees|default(0) }}</span>
                <span class="kpi-label">Dossiers Validés</span>
            </td>
            <td>
                <span class="kpi-value" style="color: #dc2626;">{{ kpis.rejetees|default(0) }}</span>
                <span class="kpi-label">Dossiers Rejetés</span>
            </td>
        </tr>
        <tr>
            <td>
                <span class="kpi-value" style="color: #00B4D8;">{{ kpis.agents_actifs|default(0) }}</span>
                <span class="kpi-label">Agents Actifs</span>
            </td>
            <td>
                <span class="kpi-value">{{ kpis.delai_moyen|default('1.5j') }}</span>
                <span class="kpi-label">Délai Moyen</span>
            </td>
            <td>
                <span class="kpi-value" style="color: #d97706;">{{ kpis.en_attente|default(0) }}</span>
                <span class="kpi-label">En Attente</span>
            </td>
        </tr>
    </table>

    <h3 style="color: #0F2D6B; border-bottom: 1px solid #eee; padding-bottom: 5px;">Répartition par type de demande</h3>
    <table>
        <thead>
            <tr>
                <th>Type de Demande</th>
                <th style="text-align: right;">Volume</th>
                <th style="text-align: right;">Pourcentage</th>
            </tr>
        </thead>
        <tbody>
            {% for type, data in types_stats %}
            <tr>
                <td>{{ type }}</td>
                <td style="text-align: right;">{{ data.count }}</td>
                <td style="text-align: right;">{{ data.percentage }}%</td>
            </tr>
            {% else %}
            <tr>
                <td colspan="3" style="text-align: center;">Aucune donnée disponible.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="footer">
        Document confidentiel - Smart e-Mairie
    </div>
</body>
</html>
