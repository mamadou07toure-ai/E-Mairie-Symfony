        .info-value { font-size: 13px; color: #0f172a; font-weight: 500; }
        
        .section-header { margin: 15px 0 10px 0; font-weight: bold; font-size: 11px; text-transform: uppercase; color: #b91c1c; border-bottom: 1.5px solid #b91c1c; width: 150px; }
        
